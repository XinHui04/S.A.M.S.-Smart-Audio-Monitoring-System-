# S.A.M.S. Environment Variables
# Copy this file to .env and fill in your values

# ── Module 2: STT — Groq API (FREE) ─────────────────────────────────────────
# 1. Go to https://console.groq.com
# 2. Sign up — no credit card needed
# 3. Go to API Keys → Create API Key
# 4. Paste it below
GROQ_API_KEY=gsk_your_key_here

# ── Module 2: NLP threshold ───────────────────────────────────────────────────
# Alert fires when threat score >= this value (0.0 to 1.0)
THREAT_SCORE_THRESHOLD=0.75

# ── Module 1: Audio settings ──────────────────────────────────────────────────
AUDIO_STORAGE_DIR=./audio_storage
VAD_ENERGY_THRESHOLD=0.01
MAX_AUDIO_DURATION=10.0

# ── Module 3: Database ────────────────────────────────────────────────────────
SQLITE_DB_PATH=./sams.db

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ── Module 4: MQTT publisher (real-time alert fan-out) ───────────────────────
# Opt-in. Leave MQTT_ENABLED=false to run without a broker (default).
# Set to true and point at a Mosquitto broker to publish alerts to the topic.
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=sams/alerts
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false
MQTT_QOS=1

# S.A.M.S. Environment Variables
# Copy this file to .env and fill in your values

# ── Module 2: STT — Groq API (FREE) ─────────────────────────────────────────
# 1. Go to https://console.groq.com
# 2. Sign up — no credit card needed
# 3. Go to API Keys → Create API Key
# 4. Paste it below
GROQ_API_KEY=gsk_your_key_here

# ── Module 2: NLP threshold ───────────────────────────────────────────────────
# Alert fires when threat score >= this value (0.0 to 1.0)
THREAT_SCORE_THRESHOLD=0.75

# ── Module 1: Audio settings ──────────────────────────────────────────────────
AUDIO_STORAGE_DIR=./audio_storage
VAD_ENERGY_THRESHOLD=0.01
MAX_AUDIO_DURATION=10.0

# ── Module 3: Database ────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use the local SQLite file below (default; dev/offline/tests).
# To use Supabase Postgres (cloud): Supabase Dashboard > Project Settings > Database >
# "Connection string" > choose the "Session pooler" tab (IPv4-friendly, port 5432), copy the
# URI, and prefix the driver as postgresql+psycopg2://  Example:
#   DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
SQLITE_DB_PATH=./sams.db

# ── Module 1/2: Audio object storage ─────────────────────────────────────────
# STORAGE_BACKEND=local (default) keeps audio clips on disk at AUDIO_STORAGE_DIR.
# Set STORAGE_BACKEND=supabase to upload clips to a Supabase Storage bucket instead.
# Get SUPABASE_URL + the service_role key from: Project Settings > API.
# The service_role key is SECRET (server-side only) — never expose it to the browser/PWA.
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=audio-clips
DELETE_LOCAL_AFTER_UPLOAD=true

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ── Module 4: MQTT publisher (real-time alert fan-out) ───────────────────────
# Opt-in. Leave MQTT_ENABLED=false to run without a broker (default).
# Set to true and point at a Mosquitto broker to publish alerts to the topic.
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=sams/alerts
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false
MQTT_QOS=1
